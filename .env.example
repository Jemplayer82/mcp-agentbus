# Shared bearer token every agent uses to authenticate to the bus.
# Generate a strong value (e.g. `openssl rand -hex 32`) and reuse it in every client config.
AGENTBUS_MCP_TOKEN=your-secret-token-here

# Optional: override the HTTP port (default 3107) and SQLite path (default /data/agentbus.db).
# PORT=3107
# AGENTBUS_DB_PATH=/data/agentbus.db
